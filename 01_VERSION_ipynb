    {
      "cell_type": "code",
      "source": [
        "import numpy as np"
      ],
      "metadata": {
        "id": "dXdi6h7uyv-a"
      },
      "execution_count": 3,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "class LinearRegression:\n",
        "    def __init__(self, learning_rate=0.01, epochs=1000):\n",
        "        self.w = 0\n",
        "        self.b = 0\n",
        "        self.learning_rate = learning_rate\n",
        "        self.epochs = epochs\n",
        "\n",
        "    def predict(self, x):\n",
        "        y = self.w * x + self.b\n",
        "        return y\n",
        "\n",
        "    def fit(self, X_train, y_train):\n",
        "        for _ in range(self.epochs):\n",
        "            y_pred = self.predict(X_train)\n",
        "            loss = np.mean((y_pred - y_train) ** 2)\n",
        "\n",
        "            dw = (2 / len(X_train)) * np.sum((y_pred - y_train) * X_train)\n",
        "            db = (2 / len(X_train)) * np.sum(y_pred - y_train)\n",
        "\n",
        "            self.w = self.w - self.learning_rate * dw\n",
        "            self.b = self.b - self.learning_rate * db"
      ],
      "metadata": {
        "id": "Wmxf3_AxytLW"
      },
      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "#Test"
      ],
      "metadata": {
        "id": "Ch6hK8Yq0MQY"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "X_train = np.array([1, 2, 3, 4, 5])\n",
        "y_train = np.array([3, 5, 7, 9, 11])"
      ],
      "metadata": {
        "id": "R6ZqsapP0Pcr"
      },
      "execution_count": 5,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "model = LinearRegression(learning_rate=0.01, epochs=1000)\n",
        "model.fit(X_train, y_train)"
